---
import { buttonVariants } from '@/components/ui/button';

interface Props {
  url: URL;
  total: number;
  page: number;
  pageSize: number;
}

const { url, total, page, pageSize } = Astro.props;
const pageCount = Math.max(1, Math.ceil(total / pageSize));
const currentPage = Math.min(page, pageCount);
const first = total === 0 ? 0 : (currentPage - 1) * pageSize + 1;
const last = Math.min(currentPage * pageSize, total);

function pageHref(nextPage: number) {
  const params = new URLSearchParams(url.searchParams);
  params.delete('filters');
  params.set('page', String(nextPage));
  return `${url.pathname}?${params}`;
}
---

<footer class="flex flex-wrap items-center gap-3 border-t bg-card p-3 text-sm">
  <span>Total Records <strong class="ml-1 tabular-nums">{total.toLocaleString()}</strong></span>
  <div class="ml-auto flex flex-wrap items-center justify-end gap-2">
    {
      currentPage > 1 ? (
        <a
          href={pageHref(currentPage - 1)}
          class={buttonVariants({ variant: 'ghost', size: 'icon-sm' })}
          aria-label="Previous page"
        >
          ‹
        </a>
      ) : (
        <span
          class={`${buttonVariants({ variant: 'ghost', size: 'icon-sm' })} pointer-events-none opacity-40`}
          aria-hidden="true"
        >
          ‹
        </span>
      )
    }
    <strong class="min-w-20 text-center tabular-nums"
      >{first.toLocaleString()} to {last.toLocaleString()}</strong
    >
    {
      currentPage < pageCount ? (
        <a
          href={pageHref(currentPage + 1)}
          class={buttonVariants({ variant: 'ghost', size: 'icon-sm' })}
          aria-label="Next page"
        >
          ›
        </a>
      ) : (
        <span
          class={`${buttonVariants({ variant: 'ghost', size: 'icon-sm' })} pointer-events-none opacity-40`}
          aria-hidden="true"
        >
          ›
        </span>
      )
    }
  </div>
</footer>
