---
import { buttonVariants } from '@/components/ui/button';
import { TABLE_PAGE_SIZES } from '@/lib/table-query';

interface Props {
	url: URL;
	query: string;
	placeholder: string;
	pageSize: number;
}

const { url, query, placeholder, pageSize } = Astro.props;
const searchHidden = [...url.searchParams.entries()].filter(([key]) => !['q', 'page', 'filters'].includes(key));
const pageSizeHidden = [...url.searchParams.entries()].filter(([key]) => !['limit', 'page', 'filters'].includes(key));
const clearParams = new URLSearchParams(url.searchParams);
clearParams.delete('q');
clearParams.delete('page');
clearParams.delete('filters');
const clearHref = `${url.pathname}${clearParams.size ? `?${clearParams}` : ''}`;
---

<div class="flex flex-wrap items-center gap-2 border-b bg-muted/20 p-2">
	<slot />
	<form method="get" class="flex items-center gap-2">
		{pageSizeHidden.map(([name, value]) => <input type="hidden" name={name} value={value} />)}
		<input type="hidden" name="page" value="1" />
		<label for="table-page-size" class="text-sm text-muted-foreground">Rows per page</label>
		<select id="table-page-size" name="limit" class="h-8 rounded-md border bg-background px-2 text-xs" onchange="this.form.requestSubmit()">
			{TABLE_PAGE_SIZES.map((value) => <option value={value} selected={value === pageSize}>{value.toLocaleString()}</option>)}
		</select>
	</form>
	<form method="get" class="flex min-w-64 flex-1 items-center gap-2">
		{searchHidden.map(([name, value]) => <input type="hidden" name={name} value={value} />)}
		<input
			type="search"
			name="q"
			value={query}
			placeholder={placeholder}
			aria-label={placeholder}
			class="h-8 min-w-0 flex-1 rounded-lg border border-input bg-background px-2.5 text-sm outline-none focus-visible:border-ring focus-visible:ring-3 focus-visible:ring-ring/50"
		/>
		<button class={buttonVariants({ size: 'sm' })}>Search</button>
		{query && <a href={clearHref} class={buttonVariants({ variant: 'ghost', size: 'sm' })}>Clear</a>}
	</form>
</div>
