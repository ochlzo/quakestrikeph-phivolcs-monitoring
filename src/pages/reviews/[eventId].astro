---
import Layout from '@/layouts/Layout.astro';
import { ReviewForm } from '@/components/review-form';
import { buttonVariants } from '@/components/ui/button';
import { getForecastCase } from '@/lib/portal-data';
const eventId = Astro.params.eventId;
if (!eventId) return Astro.redirect('/forecasts');
let item = null;
let error = '';
try {
  item = await getForecastCase(eventId);
} catch (reason) {
  error = reason instanceof Error ? reason.message : 'Could not load forecast.';
}
if (!item && !error) Astro.response.status = 404;
const forecastUrl = `https://quakestrikeph.qzz.io/forecast?event=${encodeURIComponent(eventId)}&iframe=true`;
---

<Layout title="Forecast review"
  ><main class="flex-1 p-4 sm:p-6">
    <div class="mx-auto max-w-7xl space-y-5">
      <a href="/forecasts" class={buttonVariants({ variant: 'ghost' })}>← Back to forecast list</a>{
        error || !item ? (
          <div class="rounded-xl border bg-card p-6">
            <h1 class="font-semibold">Forecast unavailable</h1>
            <p class="mt-2 text-sm text-muted-foreground">
              {error || 'No current forecast exists for this event.'}
            </p>
          </div>
        ) : (
          <>
            <header>
              <h1 class="text-2xl font-semibold">Forecast review</h1>
            </header>
            <div class="grid items-start gap-5 lg:grid-cols-[minmax(0,1.35fr)_minmax(340px,.65fr)]">
              <iframe
                title="Forecast discussion"
                src={forecastUrl}
                class="h-[75svh] w-full rounded-xl border bg-card"
              />
              <section class="h-[75svh] overflow-hidden rounded-xl border bg-card shadow-sm">
                <ReviewForm client:load item={item} />
              </section>
            </div>
          </>
        )
      }
    </div>
  </main></Layout
>
