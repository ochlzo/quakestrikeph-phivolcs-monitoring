---
import Layout from '@/layouts/Layout.astro';
import { buttonVariants } from '@/components/ui/button';
import { getAuditLogs } from '@/lib/portal-data';
const limits = [50, 100, 250, 500, 1000, 2000]; const requested = Number(Astro.url.searchParams.get('limit') ?? 50); const limit = limits.includes(requested) ? requested : 50;
let logs: Awaited<ReturnType<typeof getAuditLogs>>['logs'] = []; let total = 0; let error = '';
try { ({ logs, total } = await getAuditLogs(limit)); } catch (reason) { error = reason instanceof Error ? reason.message : 'Could not load audit logs.'; }
const PHT = new Intl.DateTimeFormat('en-PH', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Manila' });
---
<Layout title="Audit logs"><main class="flex-1 p-4 sm:p-6"><div class="mx-auto max-w-7xl space-y-5"><header><p class="text-xs font-semibold uppercase tracking-wide text-primary">Accountability</p><h1 class="text-2xl font-semibold">Operator logs</h1><p class="text-sm text-muted-foreground">Server-recorded review and profile mutations.</p></header>{error ? <div role="alert" class="rounded-lg border bg-red-50 p-4 text-destructive">{error}</div> : <section class="overflow-hidden rounded-xl border bg-card shadow-sm"><div class="overflow-x-auto"><table class="w-full text-left text-sm"><thead class="bg-muted/60 text-xs uppercase text-muted-foreground"><tr><th class="p-3">Time</th><th class="p-3">Operator</th><th class="p-3">Action</th><th class="p-3">Route</th></tr></thead><tbody class="divide-y">{logs.map((log) => <tr><td class="p-3 whitespace-nowrap">{PHT.format(new Date(log.created_at))} PHT</td><td class="p-3">{log.user_email}</td><td class="p-3 font-medium">{String(log.metadata.action ?? `${log.method} request`)}</td><td class="p-3 font-mono text-xs">{log.path}</td></tr>)}</tbody></table></div><form class="flex items-center justify-between gap-3 border-t p-3 text-sm" method="get"><label class="flex items-center gap-2">Show data<select name="limit" class="h-8 rounded-md border bg-background px-2">{limits.map((value) => <option value={value} selected={value === limit}>{value.toLocaleString()}</option>)}</select></label><span class="text-muted-foreground">{logs.length.toLocaleString()} / {total.toLocaleString()}</span><button class={buttonVariants({ variant: 'outline', size: 'sm' })}>Apply</button></form></section>}</div></main></Layout>
