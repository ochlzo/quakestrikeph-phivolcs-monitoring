---
import Layout from '@/layouts/Layout.astro';
import { buttonVariants } from '@/components/ui/button';
import { getRawEvents, type EventRow } from '@/lib/portal-data';
const limits = [50, 100, 250, 500, 1000, 2000]; const requested = Number(Astro.url.searchParams.get('limit') ?? 50); const limit = limits.includes(requested) ? requested : 50;
let events: EventRow[] = []; let error = '';
try { events = (await getRawEvents(limit)).events; } catch (reason) { error = reason instanceof Error ? reason.message : 'Could not load raw events.'; }
const PHT = new Intl.DateTimeFormat('en-PH', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Asia/Manila' });
---
<Layout title="Raw events"><main class="flex-1 p-4 sm:p-6"><div class="mx-auto max-w-7xl space-y-5"><header><p class="text-xs font-semibold uppercase tracking-wide text-primary">Catalog</p><h1 class="text-2xl font-semibold">Raw earthquake events</h1><p class="text-sm text-muted-foreground">Read-only source records. Operators cannot edit or delete catalog events.</p></header>{error ? <div role="alert" class="rounded-lg border bg-red-50 p-4 text-destructive">{error}</div> : <section class="overflow-hidden rounded-xl border bg-card shadow-sm"><div class="overflow-x-auto"><table class="w-full text-left text-sm"><thead class="bg-muted/60 text-xs uppercase text-muted-foreground"><tr><th class="p-3">Magnitude</th><th class="p-3">Location</th><th class="p-3">Event time</th><th class="p-3">Depth</th><th class="p-3">Coordinates</th></tr></thead><tbody class="divide-y">{events.map((event) => <tr><td class="p-3 font-semibold text-primary">M{event.Magnitude.toFixed(1)}</td><td class="p-3">{event.Location ?? 'Unknown location'}</td><td class="p-3">{PHT.format(new Date(event.event_time ?? event['Date-Time']))} PHT</td><td class="p-3">{event.Depth} km</td><td class="p-3 tabular-nums">{event.Latitude.toFixed(3)}, {event.Longitude.toFixed(3)}</td></tr>)}</tbody></table></div><form class="flex items-center justify-between gap-3 border-t p-3 text-sm" method="get"><label class="flex items-center gap-2">Show data<select name="limit" class="h-8 rounded-md border bg-background px-2">{limits.map((value) => <option value={value} selected={value === limit}>{value.toLocaleString()}</option>)}</select></label><span class="text-muted-foreground">{events.length.toLocaleString()} / 2,000 max</span><button class={buttonVariants({ variant: 'outline', size: 'sm' })}>Apply</button></form></section>}</div></main></Layout>
