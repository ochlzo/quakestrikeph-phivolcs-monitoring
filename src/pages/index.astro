---
import Layout from '../layouts/Layout.astro';
import Map from '../components/Map.astro';
import ZoomSlider from '../components/ZoomSlider.astro';
import { MapPageShell } from '../components/map-page-shell';
import { getOperatorProfile } from '../lib/portal-data';

const operatorEmail = Astro.locals.user?.email ?? '';
let operatorDisplayName = '';
if (operatorEmail) {
  try { operatorDisplayName = (await getOperatorProfile(operatorEmail))?.display_name ?? ''; }
  catch { operatorDisplayName = ''; }
}
---

<Layout title="Earthquake monitor" shell={false}>
  <MapPageShell client:load operatorEmail={operatorEmail} operatorDisplayName={operatorDisplayName}>
    <div class="relative h-full min-w-0 w-full overflow-hidden rounded-xl">
      <Map height="100%" />
      <ZoomSlider />
    </div>
  </MapPageShell>
</Layout>
