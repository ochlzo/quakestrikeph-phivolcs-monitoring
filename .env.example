# Exact portal origin used for same-origin mutation checks.
# Use the public HTTPS origin in production.
PORTAL_ORIGIN=http://localhost:4322

# Remotely managed Cloudflare Tunnel token.
CLOUDFLARED_TOKEN=replace-with-tunnel-token

# Cloudflare Access application values.
CF_ACCESS_AUD=replace-with-access-application-aud
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# Internal Astro port. Do not publish this port on the VPS.
ASTRO_PORT=4321

# Server-only Supabase credentials. Never prefix the secret with PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace-with-server-secret

# Optional server-only Google Maps tile key. OpenStreetMap is used when omitted.
GOOGLE_MAPS_API_KEY=

# Human-initiated PHIVOLCS-reviewed forecast email alerts.
EMAIL_ALERTS_ENABLED=true
BREVO_API_KEY=replace-with-brevo-api-key
BREVO_SENDER_EMAIL=alerts@quakestrikeph.qzz.io
BREVO_SENDER_NAME=QuakeStrike PH
PIN_ALERT_MIN_MMI=3.0

# Local `pnpm dev` only. Ignored when NODE_ENV=production.
DEV_AUTH_EMAIL=operator@example.com
