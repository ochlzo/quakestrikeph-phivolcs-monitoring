# Public portal origin used for same-origin mutation checks.
PORTAL_ORIGIN=https://monitor.example.com

# Remotely managed Cloudflare Tunnel token.
CLOUDFLARED_TOKEN=replace-with-tunnel-token

# Cloudflare Access application values.
CF_ACCESS_AUD=replace-with-access-application-aud
CF_ACCESS_TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# Internal Astro port. Do not publish this port on the VPS.
ASTRO_PORT=4321

# Server-only Supabase credentials. Never prefix the secret with PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_replace-with-server-secret

# Local `pnpm dev` only. Ignored when NODE_ENV=production.
DEV_AUTH_EMAIL=operator@example.com
